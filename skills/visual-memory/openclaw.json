{
  "name": "visual-memory",
  "displayName": "Visual Memory",
  "description": "Local photo/video indexing and visual search for OpenClaw through a standalone media-memory MCP server.",
  "version": "0.2.0",
  "license": "MIT-0",
  "homepage": "https://github.com/bkennedyshit/openclaw-polymath",
  "mcp": {
    "server": "mneme",
    "install": "mcporter add mneme -- uvx --from 'mneme-mcp[clip,video]' mneme-mcp",
    "tools": [
      "media_index",
      "media_search",
      "media_search_by_image",
      "media_describe",
      "gpu_status",
      "gpu_release",
      "gpu_reclaim",
      "gpu_evacuate"
    ]
  },
  "privacy": {
    "localOnly": true,
    "uploadsMedia": false
  }
}
